<?php
require_once 'config.php';
require_login();

// === GENERATE SITEMAP ===
if (isset($_GET['gen_sitemap'])) {
    $base = 'https://tinderfoto.ch';
    $today = date('Y-m-d');
    
    $xml = '<?xml version="1.0" encoding="UTF-8"?>' . "\n";
    $xml .= '<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">' . "\n";
    
    // Main pages
    $main = [
        ['/', '1.0', 'weekly'],
        ['/infos-faq.html', '0.8', 'monthly'],
        ['/ueber-uns.html', '0.8', 'monthly'],
        ['/buchen.html', '0.9', 'monthly'],
        ['/blog.php', '0.7', 'weekly'],
    ];
    
    foreach ($main as $p) {
        $xml .= "  <url>\n    <loc>{$base}{$p[0]}</loc>\n    <lastmod>{$today}</lastmod>\n    <changefreq>{$p[2]}</changefreq>\n    <priority>{$p[1]}</priority>\n  </url>\n";
    }
    
    // Blog posts
    $blogFiles = glob(BLOG_DIR . '*.php');
    sort($blogFiles);
    foreach ($blogFiles as $f) {
        $name = basename($f);
        if ($name === 'includes') continue;
        $lastmod = date('Y-m-d', filemtime($f));
        $xml .= "  <url>\n    <loc>{$base}/blog/{$name}</loc>\n    <lastmod>{$lastmod}</lastmod>\n    <changefreq>monthly</changefreq>\n    <priority>0.6</priority>\n  </url>\n";
    }
    
    $xml .= '</urlset>' . "\n";
    
    file_put_contents(SITE_ROOT . 'sitemap.xml', $xml);
    
    $totalUrls = count($main) + count($blogFiles);
    echo "<h2>Sitemap generiert</h2><p>{$totalUrls} URLs in sitemap.xml</p><p><a href='../sitemap.xml' target='_blank'>sitemap.xml ansehen</a></p><p><a href='blog.php'>Zurueck</a></p>";
    exit;
}


$message = '';
$posts = get_blog_posts();

// Blog-Post löschen
if (isset($_GET['delete']) && isset($_GET['confirm'])) {
    $del_file = basename($_GET['delete']);
    $del_path = BLOG_DIR . $del_file;
    if (file_exists($del_path) && preg_match('/\.html$/', $del_file)) {
        unlink($del_path);
        $message = 'Blog-Post gelöscht: ' . $del_file;
        $posts = get_blog_posts();
    }
}
?>
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tinderfoto Admin – Blog</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="admin-style.css">
</head>
<body>
    <nav class="admin-nav">
        <div class="nav-brand">
            <img src="../images/logo-tinderfoto.png" alt="Tinderfoto" height="30">
            <span>Admin</span>
        </div>
        <div class="nav-links">
            <a href="dashboard.php"><i class="fas fa-home"></i> Dashboard</a>
            <a href="edit.php"><i class="fas fa-edit"></i> Seiten</a>
            <a href="blog.php" class="active"><i class="fas fa-newspaper"></i> Blog</a>
            <a href="images.php"><i class="fas fa-images"></i> Bilder</a>
            <a href="settings.php"><i class="fas fa-cog"></i> Einstellungen</a>
            <a href="index.php?logout=1" class="logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </nav>

    <main class="admin-main">
        <div class="page-header">
            <h1><i class="fas fa-newspaper"></i> Blog-Posts (<?= count($posts) ?>)</h1>
            <a href="blog-new.php" class="btn-new"><i class="fas fa-plus"></i> Neuer Blog-Post</a>
        </div>

        <?php if ($message): ?>
            <div class="alert success"><?= htmlspecialchars($message) ?></div>
        <?php endif; ?>

        <div class="card">
            <input type="text" id="searchPosts" class="search-input" placeholder="Blog-Posts durchsuchen...">
            <table id="postsTable">
                <thead>
                    <tr><th>Titel</th><th>Datei</th><th>Geändert</th><th>Aktionen</th></tr>
                </thead>
                <tbody>
                <?php foreach ($posts as $p): ?>
                    <tr>
                        <td><?= htmlspecialchars(mb_substr($p['title'], 0, 60)) ?></td>
                        <td><code><?= htmlspecialchars($p['file']) ?></code></td>
                        <td><?= $p['modified'] ?></td>
                        <td class="actions">
                            <a href="edit.php?file=blog/<?= urlencode($p['file']) ?>" class="btn-small" title="Bearbeiten"><i class="fas fa-edit"></i></a>
                            <a href="../blog/<?= htmlspecialchars($p['file']) ?>" target="_blank" class="btn-small btn-preview-small" title="Vorschau"><i class="fas fa-eye"></i></a>
                            <a href="blog.php?delete=<?= urlencode($p['file']) ?>&confirm=1" class="btn-small btn-delete" title="Löschen" onclick="return confirm('Blog-Post wirklich löschen?')"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    </main>

    <script>
        document.getElementById('searchPosts').addEventListener('input', function() {
            var query = this.value.toLowerCase();
            var rows = document.querySelectorAll('#postsTable tbody tr');
            rows.forEach(function(row) {
                var text = row.textContent.toLowerCase();
                row.style.display = text.indexOf(query) > -1 ? '' : 'none';
            });
        });
    </script>
</body>
</html>

/* ======================================
   TINDERFOTO.CH - MAIN STYLESHEET
   Professional Photography Website
   ====================================== */

/* ======================================
   1. IMPORTS & GLOBAL RESET
   ====================================== */

@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap');

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: 'Roboto', Helvetica, Arial, sans-serif;
  font-size: 16px;
  line-height: 1.6;
  color: #666666;
  background-color: #ffffff;
}

/* ======================================
   2. TYPOGRAPHY
   ====================================== */

h1, h2, h3, h4, h5, h6 {
  color: #333333;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 1rem;
}

h1 {
  font-size: 48px;
  margin-bottom: 1.5rem;
}

h2 {
  font-size: 40px;
  margin-bottom: 1.25rem;
}

h3 {
  font-size: 32px;
  margin-bottom: 1rem;
}

h4 {
  font-size: 24px;
  margin-bottom: 0.75rem;
}

h5 {
  font-size: 20px;
  margin-bottom: 0.75rem;
}

h6 {
  font-size: 16px;
  margin-bottom: 0.5rem;
}

p {
  margin-bottom: 1rem;
}

a {
  color: #b71c1c;
  text-decoration: none;
  transition: color 0.3s ease;
}

a:hover {
  color: #8b1515;
}

ul, ol {
  margin-bottom: 1rem;
  padding-left: 2rem;
}

li {
  margin-bottom: 0.5rem;
}

/* ======================================
   3. CONTAINER & LAYOUT
   ====================================== */

.container {
  width: 100%;
  max-width: 1080px;
  margin-left: auto;
  margin-right: auto;
  padding-left: 20px;
  padding-right: 20px;
}

.content-section {
  padding-top: 60px;
  padding-bottom: 60px;
  width: 100%;
}

.content-section .container {
  max-width: 1080px;
  margin-left: auto;
  margin-right: auto;
}

.content-section .content-text,
.content-section .section-heading,
.content-section .page-title,
.content-section .inline-link {
  max-width: 700px;
}

.content-text {
  color: #666666;
  font-size: 16px;
  line-height: 1.8;
  text-align: left;
}

.section-heading {
  font-size: 28px;
  color: #711210;
  font-weight: 700;
  text-align: left;
  margin-bottom: 20px;
}

.section-title {
  font-size: 36px;
  color: #333333;
  font-weight: 700;
  margin-bottom: 20px;
  text-align: center;
}

.subtitle {
  font-size: 16px;
  color: #666666;
  text-align: center;
  margin-bottom: 40px;
  line-height: 1.6;
}

.page-title {
  font-size: 28px;
  color: #333333;
  font-weight: 700;
  margin-bottom: 10px;
  text-transform: uppercase;
  text-align: left;
}

.row {
  display: flex;
  flex-wrap: wrap;
  margin-left: -15px;
  margin-right: -15px;
}

.col {
  padding-left: 15px;
  padding-right: 15px;
}

.col-full {
  width: 100%;
}

.col-half {
  width: 50%;
}

.col-third {
  width: 33.333%;
}

.col-two-thirds {
  width: 66.666%;
}

@media (max-width: 768px) {
  .col-half, .col-third, .col-two-thirds {
    width: 100%;
  }
}

/* ======================================
   4. HEADER & NAVIGATION
   ====================================== */

header {
  position: sticky;
  top: 0;
  background-color: #ffffff;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  z-index: 1000;
  width: 100%;
  padding-top: 20px;
  padding-bottom: 20px;
  transition: box-shadow 0.3s ease;
}

header.scrolled {
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
}

.sticky-header {
  position: sticky;
  top: 0;
  z-index: 1000;
}

.header-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

header .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 100%;
  padding-left: 30px;
  padding-right: 32px;
}

.logo-container {
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo {
  font-size: 24px;
  font-weight: 700;
  color: #333333;
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  transition: color 0.3s ease;
}

.logo:hover {
  color: #b71c1c;
}

.logo img {
  height: 40px;
  width: auto;
}

.nav-desktop {
  display: flex;
  align-items: center;
  gap: 30px;
}

.nav-list {
  display: flex;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 30px;
  align-items: center;
}

.nav-link {
  color: #333333;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  transition: color 0.3s ease;
}

.nav-link:hover {
  color: #b71c1c;
}

.nav-link.active {
  color: #b71c1c;
}

.main-nav {
  display: flex;
  align-items: center;
  gap: 30px;
}

nav {
  display: flex;
  align-items: center;
  gap: 30px;
}

nav a {
  color: #333333;
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 1px;
  text-transform: uppercase;
  transition: color 0.3s ease;
}

nav a:hover {
  color: #b71c1c;
}

nav a.active {
  color: #b71c1c;
}

.nav-mobile {
  display: none;
  flex-direction: column;
  gap: 10px;
  padding-top: 20px;
  padding-bottom: 20px;
}

.mobile-menu-toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  flex-direction: column;
  gap: 6px;
  padding: 0;
}

.mobile-menu-toggle span {
  width: 25px;
  height: 2px;
  background-color: #333333;
  transition: all 0.3s ease;
}

/* Hamburger Menu */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 6px;
  cursor: pointer;
  width: 30px;
  height: 24px;
  justify-content: center;
  background: none;
  border: none;
  padding: 0;
}

.hamburger span {
  width: 100%;
  height: 2px;
  background-color: #333333;
  transition: all 0.3s ease;
}

.hamburger.active span:nth-child(1) {
  transform: rotate(45deg) translateY(10px);
}

.hamburger.active span:nth-child(2) {
  opacity: 0;
}

.hamburger.active span:nth-child(3) {
  transform: rotate(-45deg) translateY(-10px);
}

/* Mobile Navigation */
@media (max-width: 768px) {
  .nav-desktop {
    display: none;
  }

  header .header-content nav,
  header nav.nav {
    display: none;
    position: absolute;
    top: 70px;
    left: 0;
    right: 0;
    background-color: #ffffff;
    flex-direction: column;
    gap: 0;
    padding-top: 20px;
    padding-bottom: 20px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    align-items: stretch;
    z-index: 999;
  }

  body.nav-open header nav,
  body.nav-open header .header-content nav {
    display: flex;
    flex-direction: column;
  }

  nav a,
  nav .nav-link {
    padding-left: 20px;
    padding-right: 20px;
    padding-top: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f0f0f0;
    display: block;
  }

  nav a:last-child,
  nav .nav-link:last-child {
    border-bottom: none;
  }

  .hamburger {
    display: flex;
  }

  .mobile-menu-toggle {
    display: flex;
  }

  header {
    position: relative;
  }
}

/* ======================================
   5. BUTTONS & CALL-TO-ACTION
   ====================================== */

.btn, button, input[type="submit"], input[type="button"] {
  display: inline-block;
  background-color: #b71c1c;
  color: #ffffff;
  padding-top: 12px;
  padding-bottom: 12px;
  padding-left: 24px;
  padding-right: 24px;
  border: none;
  border-radius: 0;
  font-size: 14px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
  transition: background-color 0.3s ease, color 0.3s ease;
  text-decoration: none;
  font-family: 'Roboto', Helvetica, Arial, sans-serif;
}

.btn:hover, button:hover, input[type="submit"]:hover, input[type="button"]:hover {
  background-color: #8b1515;
  color: #ffffff;
}

.cta-button {
  display: inline-block;
  background-color: #b71c1c;
  color: #ffffff;
  padding: 12px 28px;
  border: none;
  border-radius: 0;
  font-size: 14px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
  transition: background-color 0.3s ease;
  text-decoration: none;
}

.cta-button:hover {
  background-color: #8b1515;
}

.cta-primary {
  background-color: #b71c1c;
  color: #ffffff;
  padding: 12px 28px;
  border: none;
  text-transform: uppercase;
  font-weight: 500;
  letter-spacing: 1px;
}

.cta-primary:hover {
  background-color: #8b1515;
}

.btn.btn-secondary {
  background-color: #333333;
  color: #ffffff;
}

.btn.btn-secondary:hover {
  background-color: #000000;
}

.btn.btn-outline {
  background-color: transparent;
  color: #ffffff;
  border: 2px solid #ffffff;
}

.btn.btn-outline:hover {
  background-color: #ffffff;
  color: #333333;
}

.btn.btn-large {
  padding-top: 16px;
  padding-bottom: 16px;
  padding-left: 32px;
  padding-right: 32px;
  font-size: 16px;
}

.btn.btn-small {
  padding-top: 8px;
  padding-bottom: 8px;
  padding-left: 16px;
  padding-right: 16px;
  font-size: 12px;
}

.btn-group {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
}

.btn-submit {
  background-color: #b71c1c;
  color: #ffffff;
  padding: 12px 28px;
  border: none;
  border-radius: 0;
  font-size: 14px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 1px;
  cursor: pointer;
  transition: background-color 0.3s ease;
  width: 100%;
}

.btn-submit:hover {
  background-color: #8b1515;
}

.btn-search {
  background-color: #b71c1c;
  color: #ffffff;
  padding: 10px 15px;
  border: none;
  font-size: 12px;
  font-weight: 500;
  text-transform: uppercase;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.btn-search:hover {
  background-color: #8b1515;
}

@media (max-width: 768px) {
  .btn-group {
    flex-direction: column;
  }

  .btn-group .btn {
    width: 100%;
    text-align: center;
  }
}

/* ======================================
   6. HERO SECTION
   ====================================== */

.hero {
  position: relative;
  width: 100%;
  min-height: 600px;
  height: 600px;
  background-size: cover;
  background-position: 50% 8%;
  background-repeat: no-repeat;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(109deg, rgba(0, 0, 0, 0.7) 21%, rgba(0, 0, 0, 0) 68%);
  z-index: 1;
}

.hero-overlay {
  display: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: left;
  color: #ffffff;
  max-width: 680px;
  padding-left: 80px;
  padding-right: 20px;
}

.hero-title {
  color: #ffffff;
  font-size: 40px;
  margin-bottom: 15px;
  font-weight: 700;
  line-height: 1.2;
}

.hero-subtitle {
  color: #ffffff;
  font-size: 16px;
  margin-bottom: 10px;
  font-weight: 400;
}

.hero-description {
  color: #ffffff;
  font-size: 18px;
  margin-bottom: 25px;
  line-height: 1.6;
  font-weight: 700;
}

.hero-text {
  color: #ffffff;
  font-size: 18px;
  margin-bottom: 30px;
  line-height: 1.8;
}

.hero-intro {
  color: #ffffff;
  font-size: 16px;
  margin-bottom: 20px;
}

.hero-call {
  color: #ffffff;
  font-size: 20px;
  margin-bottom: 30px;
  font-weight: 500;
}

.hero h1 {
  color: #ffffff;
  font-size: 56px;
  margin-bottom: 20px;
  font-weight: 700;
}

.hero p {
  color: #ffffff;
  font-size: 20px;
  margin-bottom: 30px;
  line-height: 1.6;
}

.hero .btn,
.hero .cta-button {
  background-color: rgba(255, 255, 255, 0.4);
  border: 2px solid #ffffff;
  color: #ffffff;
  padding-top: 12px;
  padding-bottom: 12px;
  padding-left: 24px;
  padding-right: 24px;
  text-transform: uppercase;
  letter-spacing: 1px;
  font-size: 14px;
  font-weight: 500;
}

.hero .btn:hover,
.hero .cta-button:hover {
  background-color: rgba(255, 255, 255, 0.6);
  color: #ffffff;
}

.wave-divider {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80px;
  z-index: 3;
  overflow: hidden;
}

.wave-divider svg {
  width: 100%;
  height: 100%;
  display: block;
}

@media (max-width: 768px) {
  .hero {
    min-height: 400px;
  }

  .hero h1 {
    font-size: 36px;
  }

  .hero p {
    font-size: 16px;
  }

  .hero-title {
    font-size: 36px;
  }

  .hero-subtitle {
    font-size: 18px;
  }
}

/* ======================================
   7. INTRO SECTION
   ====================================== */

.intro-section {
  padding-top: 60px;
  padding-bottom: 60px;
}

.intro-text {
  font-size: 18px;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 20px;
}

.intro-link {
  color: #b71c1c;
  text-decoration: none;
  font-weight: 500;
  transition: color 0.3s ease;
}

.intro-link:hover {
  color: #8b1515;
}

.inline-link {
  color: #b71c1c;
  text-decoration: none;
  transition: color 0.3s ease;
}

.inline-link:hover {
  color: #8b1515;
  text-decoration: underline;
}

/* ======================================
   8. SERVICE/OFFERING BOXES
   ====================================== */

.boxes-section {
  padding-top: 60px;
  padding-bottom: 60px;
}

.boxes-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;
  margin-bottom: 30px;
}

.info-box {
  padding-left: 30px;
  padding-right: 30px;
  padding-top: 40px;
  padding-bottom: 40px;
  background-color: #f5f5f5;
  border: 1px solid #e0e0e0;
  text-align: center;
  transition: box-shadow 0.3s ease;
}

.info-box:hover {
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  transform: translateY(-5px);
}

.box-title {
  font-size: 22px;
  color: #333333;
  font-weight: 700;
  margin-bottom: 15px;
}

.box-list {
  list-style: none;
  padding: 0;
  margin: 0;
  text-align: center;
}

.box-list li {
  padding: 8px 0;
  color: #666666;
  font-size: 14px;
  margin: 0;
}

.box-list li:before {
  content: '■';
  color: #333333;
  font-size: 8px;
  display: inline-block;
  width: 1.5em;
  margin-left: -1.5em;
  vertical-align: middle;
}

.box-link {
  color: #b71c1c;
  text-decoration: none;
  font-weight: 500;
  transition: color 0.3s ease;
}

.box-link:hover {
  color: #8b1515;
}

.boxes-cta {
  text-align: left;
  margin-top: 30px;
}

.menu-box {
  padding: 30px;
  background-color: #ffffff;
  border: 1px solid #e0e0e0;
  text-align: center;
  transition: box-shadow 0.3s ease;
}

.menu-box:hover {
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
}

.box {
  padding-left: 30px;
  padding-right: 30px;
  padding-top: 30px;
  padding-bottom: 30px;
  background-color: #ffffff;
  border: 1px solid #e0e0e0;
  text-align: center;
  transition: box-shadow 0.3s ease, transform 0.3s ease;
  margin-bottom: 30px;
}

.box:hover {
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  transform: translateY(-5px);
}

.box-icon {
  font-size: 48px;
  color: #b71c1c;
  margin-bottom: 20px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.box h3 {
  font-size: 22px;
  margin-bottom: 15px;
  color: #333333;
}

.box p {
  color: #666666;
  font-size: 16px;
  line-height: 1.6;
}

.box-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  margin-bottom: 30px;
}

@media (max-width: 1024px) {
  .boxes-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .box-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .boxes-grid {
    grid-template-columns: 1fr;
  }

  .box-grid {
    grid-template-columns: 1fr;
  }

  .box {
    padding-left: 20px;
    padding-right: 20px;
    padding-top: 20px;
    padding-bottom: 20px;
  }

  .info-box {
    padding-left: 20px;
    padding-right: 20px;
    padding-top: 20px;
    padding-bottom: 20px;
  }
}

/* ======================================
   9. PROCESS STEPS
   ====================================== */

.process-section {
  padding-top: 60px;
  padding-bottom: 60px;
}

.process-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 30px;
  margin-bottom: 30px;
}

.process-step {
  text-align: center;
}

.process-icon {
  font-size: 48px;
  color: #b71c1c;
  margin-bottom: 15px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: auto;
  margin-right: auto;
}

.process-title {
  font-size: 18px;
  color: #333333;
  font-weight: 700;
  margin-bottom: 10px;
}

.process-text {
  font-size: 14px;
  color: #666666;
  line-height: 1.6;
}

.process-cta {
  text-align: left;
  margin-top: 30px;
}

.steps-container {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30px;
  margin-bottom: 30px;
}

.step {
  text-align: center;
}

.step-number {
  width: 60px;
  height: 60px;
  background-color: #b71c1c;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 700;
  margin-left: auto;
  margin-right: auto;
  margin-bottom: 15px;
}

.step-icon {
  font-size: 40px;
  color: #b71c1c;
  margin-bottom: 15px;
}

.step h4 {
  color: #333333;
  margin-bottom: 10px;
}

.step p {
  color: #666666;
  font-size: 14px;
}

@media (max-width: 1024px) {
  .process-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .steps-container {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .process-grid {
    grid-template-columns: 1fr;
  }

  .steps-container {
    grid-template-columns: 1fr;
  }

  .step {
    text-align: center;
  }
}

/* ======================================
   10. PRICING TABLES
   ====================================== */

.pricing-section {
  padding-top: 60px;
  padding-bottom: 60px;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;
  margin-bottom: 30px;
}

.pricing-card {
  background-color: #ffffff;
  border: 1px solid #bebebe;
  overflow: hidden;
  transition: box-shadow 0.3s ease;
}

.pricing-card:hover {
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
}

.pricing-basic {
  border: 1px solid #e0e0e0;
}

.pricing-pro {
  border: 1px solid #e0e0e0;
}

.pricing-featured {
  border: 2px solid #b71c1c;
  transform: none;
}

.pricing-header {
  padding-top: 30px;
  padding-bottom: 30px;
  text-align: center;
  color: #ffffff;
  font-weight: 700;
  font-size: 20px;
  text-transform: uppercase;
  letter-spacing: 1px;
  background-color: #333333;
}

.pricing-header.basic {
  background-color: #333333;
}

.pricing-header.pro {
  background-color: #000000;
}

.pricing-header.premium {
  background-color: #b71c1c;
}

.pricing-name {
  font-size: 20px;
  font-weight: 700;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.pricing-badge {
  display: inline-block;
  background-color: #b71c1c;
  color: #ffffff;
  padding: 5px 10px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-top: 10px;
}

.pricing-price {
  padding-top: 30px;
  padding-bottom: 10px;
  text-align: center;
  color: #dc1021;
  font-size: 80px;
  font-weight: 700;
}

.price-amount {
  font-size: 80px;
  color: #dc1021;
  font-weight: 700;
}

.price-highlight {
  color: #dc1021;
  font-weight: 700;
}

.pricing-currency {
  font-size: 28px;
}

.pricing-subtitle {
  padding-bottom: 30px;
  text-align: center;
  color: #666666;
  font-size: 14px;
}

.pricing-body {
  padding: 20px 30px;
}

.pricing-features {
  padding-left: 30px;
  padding-right: 30px;
  padding-top: 20px;
  padding-bottom: 30px;
  border-bottom: 1px solid #e0e0e0;
}

.pricing-features ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.pricing-features li {
  padding-top: 12px;
  padding-bottom: 12px;
  color: #666666;
  font-size: 14px;
  border-bottom: 1px solid #f0f0f0;
  margin: 0;
}

.pricing-features li:before {
  content: '●';
  color: #dc1021;
  font-size: 10px;
  display: inline-block;
  width: 1.5em;
  margin-right: 0.5em;
  vertical-align: middle;
}

.pricing-features li:last-child {
  border-bottom: none;
}

.pricing-footer {
  padding-left: 30px;
  padding-right: 30px;
  padding-top: 20px;
  padding-bottom: 20px;
  text-align: center;
}

.pricing-footer .btn {
  width: 100%;
}

.section-cta {
  text-align: left;
  padding-top: 40px;
  margin-bottom: 50px;
}

.pricing-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  margin-bottom: 30px;
}

.pricing-table {
  background-color: #ffffff;
  border: 1px solid #e0e0e0;
  overflow: hidden;
}

.pricing-period {
  padding-bottom: 30px;
  text-align: center;
  color: #666666;
  font-size: 14px;
}

.pricing-amount {
  padding-top: 30px;
  padding-bottom: 10px;
  text-align: center;
  color: #b71c1c;
  font-size: 60px;
  font-weight: 700;
}

@media (max-width: 1024px) {
  .pricing-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .pricing-container {
    grid-template-columns: repeat(2, 1fr);
  }

  .pricing-featured {
    grid-column: 1 / -1;
    max-width: 50%;
    margin-left: auto;
    margin-right: auto;
  }

  .pricing-table:nth-child(3) {
    grid-column: 1 / -1;
    max-width: 50%;
    margin-left: auto;
    margin-right: auto;
  }
}

@media (max-width: 768px) {
  .pricing-grid {
    grid-template-columns: 1fr;
  }

  .pricing-container {
    grid-template-columns: 1fr;
  }

  .pricing-featured {
    transform: scale(1);
  }

  .pricing-table:nth-child(3) {
    grid-column: auto;
    max-width: 100%;
  }
}

/* ======================================
   11. TESTIMONIALS
   ====================================== */

.testimonials-section {
  padding-top: 60px;
  padding-bottom: 60px;
}

.testimonials-title {
  font-size: 28px;
  color: #711210;
  text-align: left;
  margin-bottom: 20px;
  font-weight: 700;
  font-style: normal;
}

.testimonials-intro {
  font-size: 16px;
  color: #666666;
  text-align: left;
  margin-bottom: 40px;
  line-height: 1.6;
}

.testimonials-grid {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 30px;
}

.testimonial {
  background-color: #f9f9f9;
  padding-left: 30px;
  padding-right: 30px;
  padding-top: 30px;
  padding-bottom: 30px;
  border: 1px solid #e0e0e0;
  position: relative;
}

.testimonial-card {
  background-color: #f9f9f9;
  padding: 30px;
  border: 1px solid #e0e0e0;
}

.testimonial-icon {
  font-size: 32px;
  color: #b71c1c;
  margin-bottom: 15px;
  opacity: 0.5;
}

.testimonial-text {
  font-style: italic;
  color: #666666;
  margin-bottom: 20px;
  line-height: 1.8;
}

.testimonial-author {
  font-weight: 700;
  color: #333333;
  margin-bottom: 5px;
}

.testimonial-role {
  font-size: 12px;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.testimonial-rating {
  margin-top: 15px;
  color: #b71c1c;
  font-size: 14px;
}

.testimonial-quote {
  font-size: 32px;
  color: #b71c1c;
  margin-bottom: 15px;
  opacity: 0.5;
}

.testimonials-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30px;
  margin-bottom: 30px;
}

@media (max-width: 768px) {
  .testimonials-grid {
    grid-template-columns: 1fr;
  }

  .testimonials-container {
    grid-template-columns: 1fr;
  }
}

/* ======================================
   12. FORMS
   ====================================== */

.booking-form-section {
  padding-top: 40px;
  padding-bottom: 60px;
  background-color: #ffffff;
  border-top: 1px solid #e0e0e0;
}

.booking-form-title {
  font-size: 26px;
  font-weight: 700;
  color: #333333;
  margin-bottom: 30px;
}

.booking-form {
  max-width: 100%;
  background-color: transparent;
  padding: 0;
  border: none;
}

.booking-form .form-group {
  margin-bottom: 20px;
}

.booking-form input[type="text"],
.booking-form input[type="email"],
.booking-form input[type="tel"],
.booking-form textarea,
.booking-form select {
  width: 100%;
  padding: 16px;
  font-size: 14px;
  border: 1px solid #bbbbbb;
  background-color: #ffffff;
  color: #333333;
  font-family: 'Roboto', sans-serif;
}

.booking-form input[type="text"]:focus,
.booking-form input[type="email"]:focus,
.booking-form input[type="tel"]:focus,
.booking-form textarea:focus {
  border-color: #b71c1c;
  outline: none;
}

.booking-form textarea {
  resize: vertical;
}

.form-label {
  font-size: 14px;
  color: #666666;
  margin-bottom: 8px;
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.radio-label {
  font-size: 14px;
  color: #333333;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
}

.form-bottom {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 15px;
  margin-top: 20px;
}

.captcha-inline {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  color: #333333;
}

.captcha-inline input {
  width: 60px;
  padding: 8px;
  font-size: 16px;
  border: 1px solid #bbbbbb;
  text-align: center;
}

.btn-submit-inline {
  background-color: #dc1021;
  color: #ffffff;
  border: none;
  padding: 10px 24px;
  font-size: 18px;
  font-weight: 500;
  cursor: pointer;
  font-family: 'Roboto', sans-serif;
  transition: background-color 0.3s ease;
}

.btn-submit-inline:hover {
  background-color: #b71c1c;
}

.form-error {
  background-color: #ffebee;
  border: 1px solid #dc1021;
  color: #dc1021;
  padding: 15px 0;
  text-align: center;
  font-size: 14px;
}

.booking-intro {
  text-align: center;
  padding: 60px 0 30px;
}

.booking-intro h1 {
  font-size: 28px;
  font-weight: 500;
  color: #000000;
  margin-bottom: 15px;
}

.booking-intro .subtitle {
  font-size: 16px;
  color: #000000;
}

.booking-intro .note {
  background-color: #f0f0f0;
  padding: 15px 20px;
  border-left: 4px solid #b71c1c;
  text-align: center;
  color: #666666;
  font-size: 14px;
  margin-top: 20px;
}

.contact-form-section {
  padding-top: 60px;
  padding-bottom: 60px;
}

.contact-hero {
  text-align: center;
  margin-bottom: 50px;
}

form {
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.form-group {
  margin-bottom: 20px;
}

label {
  display: block;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8px;
  font-size: 14px;
}

input[type="text"],
input[type="email"],
input[type="phone"],
input[type="date"],
input[type="time"],
input[type="number"],
textarea,
select {
  width: 100%;
  padding-top: 12px;
  padding-bottom: 12px;
  padding-left: 15px;
  padding-right: 15px;
  border: 1px solid #d0d0d0;
  border-radius: 0;
  font-family: 'Roboto', Helvetica, Arial, sans-serif;
  font-size: 16px;
  color: #333333;
  background-color: #ffffff;
  transition: border-color 0.3s ease;
}

input[type="text"]:focus,
input[type="email"]:focus,
input[type="phone"]:focus,
input[type="date"]:focus,
input[type="time"]:focus,
input[type="number"]:focus,
textarea:focus,
select:focus {
  outline: none;
  border-color: #b71c1c;
  box-shadow: 0 0 0 3px rgba(183, 28, 28, 0.1);
}

textarea {
  resize: vertical;
  min-height: 150px;
}

.form-row {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.form-wrapper {
  margin-bottom: 20px;
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}

.radio-label {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  font-weight: 400;
  margin-bottom: 0;
}

.radio-label input {
  margin-bottom: 0;
}

.captcha {
  margin-bottom: 20px;
  padding: 15px;
  border: 1px solid #d0d0d0;
  background-color: #f9f9f9;
}

.form-checkbox {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}

input[type="checkbox"],
input[type="radio"] {
  width: 18px;
  height: 18px;
  cursor: pointer;
  accent-color: #b71c1c;
  margin: 0;
}

.checkbox-label {
  margin: 0;
  cursor: pointer;
  font-weight: 400;
}

.form-submit {
  text-align: center;
  margin-top: 30px;
}

.form-submit .btn {
  min-width: 200px;
}

@media (max-width: 768px) {
  .form-row {
    grid-template-columns: 1fr;
  }

  .booking-form {
    padding: 30px 20px;
  }
}

/* ======================================
   13. FAQ ACCORDION
   ====================================== */

.faq-accordion {
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}

.faq-item {
  border: 1px solid #e0e0e0;
  margin-bottom: 15px;
  background-color: #ffffff;
}

.faq-question {
  padding-top: 20px;
  padding-bottom: 20px;
  padding-left: 25px;
  padding-right: 25px;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #f9f9f9;
  transition: background-color 0.3s ease;
}

.faq-question:hover {
  background-color: #f0f0f0;
}

.faq-question h4 {
  margin: 0;
  color: #333333;
  font-size: 16px;
  font-weight: 600;
}

.faq-icon {
  color: #b71c1c;
  font-size: 20px;
  font-weight: 700;
  transition: transform 0.3s ease;
}

.faq-item.active .faq-icon {
  transform: rotate(180deg);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.faq-item.active .faq-answer {
  max-height: 1000px;
}

.faq-content {
  padding-top: 20px;
  padding-bottom: 20px;
  padding-left: 25px;
  padding-right: 25px;
  color: #666666;
  line-height: 1.8;
}

.faq-toggle {
  color: #b71c1c;
  font-size: 20px;
  font-weight: 700;
  transition: transform 0.3s ease;
}

.faq-item.active .faq-toggle {
  transform: rotate(180deg);
}

.faq-container {
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}

.note {
  background-color: #f0f0f0;
  border-left: 4px solid #b71c1c;
  padding: 15px 20px;
  margin-bottom: 20px;
  color: #666666;
}

/* ======================================
   14. TEAM SECTION (ÜBER UNS)
   ====================================== */

.about-hero {
  background-color: #c62828;
  color: #ffffff;
  padding-top: 80px;
  padding-bottom: 80px;
  text-align: center;
}

.about-hero h2 {
  color: #ffffff;
  font-size: 48px;
  margin-bottom: 30px;
}

.about-hero p {
  color: #ffffff;
  font-size: 18px;
  line-height: 1.8;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
  margin-bottom: 30px;
}

.about-hero .btn {
  background-color: #ffffff;
  color: #c62828;
  border: none;
}

.about-hero .btn:hover {
  background-color: #f0f0f0;
  color: #c62828;
}

.about-intro {
  padding-top: 40px;
  padding-bottom: 40px;
  text-align: center;
}

.team-section {
  padding-top: 60px;
  padding-bottom: 60px;
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  margin-bottom: 30px;
}

.team-region {
  margin-bottom: 60px;
}

.team-region-title {
  font-size: 32px;
  color: #333333;
  text-align: center;
  margin-bottom: 40px;
  font-weight: 700;
}

.team-member {
  text-align: center;
}

.team-member-image {
  width: 100%;
  height: 300px;
  object-fit: cover;
  margin-bottom: 20px;
  border-radius: 50%;
}

.team-member-content {
  text-align: center;
}

.team-member-name {
  font-size: 22px;
  color: #333333;
  font-weight: 700;
  margin-bottom: 5px;
}

.team-member-title {
  color: #b71c1c;
  font-weight: 600;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 15px;
}

.team-member-bio {
  color: #666666;
  font-size: 14px;
  line-height: 1.6;
}

.team-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  margin-bottom: 30px;
}

.team-image {
  width: 100%;
  height: 300px;
  object-fit: cover;
  margin-bottom: 20px;
}

.team-member h3 {
  color: #333333;
  font-size: 22px;
  margin-bottom: 5px;
}

.team-member .role {
  color: #b71c1c;
  font-weight: 600;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 15px;
}

.team-member p {
  color: #666666;
  font-size: 14px;
  line-height: 1.6;
}

/* ======================================
   15. FEATURES SECTION
   ====================================== */

.features-section {
  padding-top: 60px;
  padding-bottom: 60px;
}

.feature {
  margin-bottom: 40px;
  display: flex;
  gap: 30px;
  align-items: flex-start;
}

.feature-icon {
  font-size: 48px;
  color: #b71c1c;
  flex-shrink: 0;
  width: 70px;
  height: 70px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-text {
  flex: 1;
}

.feature-text h3 {
  margin-bottom: 15px;
  color: #333333;
}

.feature-text p {
  color: #666666;
  font-size: 16px;
  line-height: 1.8;
}

@media (max-width: 1024px) {
  .team-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .team-container {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .team-grid {
    grid-template-columns: 1fr;
  }

  .team-container {
    grid-template-columns: 1fr;
  }

  .feature {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .feature-icon {
    width: auto;
    height: auto;
  }
}

/* ======================================
   16. BLOG SECTION
   ====================================== */

.blog-page {
  padding-top: 60px;
  padding-bottom: 60px;
}

.blog-container {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 40px;
}

.blog-wrapper {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 40px;
}

.blog-main {
  min-width: 0;
}

.blog-posts {
  margin-bottom: 30px;
}

.blog-post {
  margin-bottom: 40px;
  padding-bottom: 40px;
  border-bottom: 1px solid #e0e0e0;
}

.blog-post:last-child {
  border-bottom: none;
}

.blog-post .post-image {
  display: block;
  margin-bottom: 15px;
}

.blog-post .post-image img {
  width: 100%;
  height: auto;
  display: block;
}

.blog-content {
  margin-bottom: 20px;
}

.blog-intro {
  font-size: 18px;
  color: #666666;
  margin-bottom: 30px;
}

.blog-sidebar {
  min-width: 0;
}

.blog-single {
  max-width: 100%;
  padding-top: 40px;
  padding-bottom: 40px;
}

.blog-single .blog-wrapper {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 40px;
}

.blog-single h1 {
  color: #333333;
  font-size: 32px;
  margin-bottom: 20px;
  margin-top: 0;
  clear: both;
}

.blog-single .blog-meta {
  margin-bottom: 30px;
}

.post-header {
  margin-bottom: 30px;
}

.post-meta {
  color: #999999;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 15px;
  display: flex;
  gap: 20px;
}

.post-meta span {
  display: flex;
  align-items: center;
  gap: 5px;
}

.post-image {
  width: 100%;
  height: auto;
  margin-bottom: 20px;
}

.post-body {
  color: #666666;
  font-size: 16px;
  line-height: 1.9;
  margin-bottom: 30px;
}

.post-content {
  color: #666666;
  font-size: 16px;
  line-height: 1.9;
}

.post-text {
  font-size: 16px;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 20px;
}

.post-excerpt {
  color: #666666;
  font-size: 16px;
  line-height: 1.8;
  margin-bottom: 20px;
}

.featured-image {
  width: 100%;
  margin-bottom: 25px;
  overflow: hidden;
}

.featured-image img {
  width: 100%;
  height: auto;
  display: block;
}

.category {
  display: inline-block;
  background-color: #b71c1c;
  color: #ffffff;
  padding: 5px 10px;
  font-size: 12px;
  font-weight: 500;
  text-transform: uppercase;
  margin-bottom: 15px;
}

.date {
  color: #999999;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.author {
  color: #999999;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.sidebar {
  display: flex;
  flex-direction: column;
  gap: 30px;
}

.sidebar-widget {
  background-color: #f9f9f9;
  padding-left: 20px;
  padding-right: 20px;
  padding-top: 20px;
  padding-bottom: 20px;
  margin-bottom: 30px;
  border: 1px solid #e0e0e0;
}

.sidebar-widget h3 {
  font-size: 18px;
  color: #333333;
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 2px solid #b71c1c;
}

.sidebar-widget ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.sidebar-widget li {
  margin-bottom: 0;
  padding-bottom: 12px;
  border-bottom: 1px solid #e0e0e0;
}

.sidebar-widget li:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.sidebar-widget a {
  color: #333333;
  font-size: 14px;
  transition: color 0.3s ease;
}

.sidebar-widget a:hover {
  color: #b71c1c;
}

.search-widget {
  display: flex;
  gap: 10px;
  margin-bottom: 30px;
}

.search-box {
  flex: 1;
  padding: 10px 12px;
  border: 1px solid #d0d0d0;
  border-radius: 0;
  font-size: 14px;
}

.btn-search {
  padding: 10px 15px;
  font-size: 12px;
}

.latest-posts {
  list-style: none;
  padding: 0;
  margin: 0;
}

.categories {
  list-style: none;
  padding: 0;
  margin: 0;
}

.widget-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.blog-featured-image {
  width: 100%;
  height: 300px;
  object-fit: cover;
  margin-bottom: 20px;
}

.blog-meta {
  color: #999999;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 15px;
  display: flex;
  gap: 20px;
}

.blog-meta span {
  display: flex;
  align-items: center;
  gap: 5px;
}

.blog-post h2 {
  color: #333333;
  font-size: 28px;
  margin-bottom: 15px;
  margin-top: 0;
}

.blog-post h2 a {
  color: #333333;
}

.blog-post h2 a:hover {
  color: #b71c1c;
}

.blog-excerpt {
  color: #666666;
  font-size: 16px;
  line-height: 1.8;
  margin-bottom: 20px;
}

.blog-read-more {
  display: inline-block;
  color: #b71c1c;
  font-weight: 600;
  text-transform: uppercase;
  font-size: 12px;
  letter-spacing: 1px;
  transition: color 0.3s ease;
}

.blog-read-more:hover {
  color: #8b1515;
}

.blog-single-content {
  color: #666666;
  font-size: 16px;
  line-height: 1.9;
}

.blog-single-content p {
  margin-bottom: 20px;
}

.blog-single-content h2 {
  color: #333333;
  font-size: 28px;
  margin-top: 40px;
  margin-bottom: 20px;
}

.blog-single-content h3 {
  color: #333333;
  font-size: 22px;
  margin-top: 30px;
  margin-bottom: 15px;
}

.blog-single-content img {
  max-width: 100%;
  height: auto;
  margin-top: 20px;
  margin-bottom: 20px;
  display: block;
}

.sidebar-search {
  display: flex;
  gap: 10px;
  margin-bottom: 30px;
}

.sidebar-search input {
  flex: 1;
  padding-top: 10px;
  padding-bottom: 10px;
  padding-left: 12px;
  padding-right: 12px;
  border: 1px solid #d0d0d0;
  border-radius: 0;
  font-size: 14px;
}

.sidebar-search button {
  padding-top: 10px;
  padding-bottom: 10px;
  padding-left: 15px;
  padding-right: 15px;
  font-size: 12px;
}

@media (max-width: 768px) {
  .blog-container {
    grid-template-columns: 1fr;
  }

  .blog-wrapper {
    grid-template-columns: 1fr;
  }

  .blog-sidebar {
    grid-column: 1;
    grid-row: 2;
  }
}

/* ======================================
   17. FOOTER
   ====================================== */

footer {
  background-color: #222222;
  color: #ffffff;
  padding-top: 50px;
  padding-bottom: 30px;
}

.footer-section {
  background-color: #222222;
  color: #ffffff;
  padding: 50px 20px 30px;
}

.footer-top {
  margin-bottom: 40px;
}

.footer-content {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px;
  margin-bottom: 40px;
}

.footer-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px;
  margin-bottom: 40px;
}

.footer-column {
  display: flex;
  flex-direction: column;
}

.footer-col {
  margin-bottom: 30px;
}

.footer-left {
  flex: 1;
}

.footer-right {
  flex: 1;
}

.footer-heading {
  color: #b71c1c;
  font-size: 18px;
  margin-bottom: 20px;
  font-weight: 700;
}

.footer-company {
  margin-bottom: 20px;
}

.footer-company h3 {
  color: #ffffff;
  margin-bottom: 15px;
}

.footer-address {
  color: #cccccc;
  font-size: 14px;
  line-height: 1.8;
  margin-bottom: 15px;
}

.footer-contact {
  color: #cccccc;
  font-size: 14px;
  margin-bottom: 10px;
}

.footer-bottom {
  border-top: 1px solid #333333;
  padding-top: 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-copyright {
  color: #999999;
  font-size: 12px;
}

.footer-widget h3 {
  color: #ffffff;
  font-size: 18px;
  margin-bottom: 20px;
}

.footer-widget p {
  color: #cccccc;
  font-size: 14px;
  line-height: 1.8;
  margin-bottom: 15px;
}

.footer-widget ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.footer-widget li {
  margin-bottom: 10px;
}

.footer-widget a {
  color: #cccccc;
  font-size: 14px;
  transition: color 0.3s ease;
}

.footer-widget a:hover {
  color: #ffffff;
}

.footer-social {
  display: flex;
  gap: 20px;
  margin-top: 20px;
}

.footer-social a {
  width: 40px;
  height: 40px;
  background-color: #333333;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 18px;
  transition: background-color 0.3s ease;
}

.footer-social a:hover {
  background-color: #b71c1c;
}

.footer-links {
  display: flex;
  gap: 30px;
}

.footer-links a {
  color: #cccccc;
  font-size: 12px;
  transition: color 0.3s ease;
}

.footer-links a:hover {
  color: #ffffff;
}

@media (max-width: 768px) {
  .footer-content {
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .footer-grid {
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .footer-bottom {
    flex-direction: column;
    gap: 20px;
    text-align: center;
  }

  .footer-links {
    flex-direction: column;
    gap: 15px;
    justify-content: center;
  }
}

/* WhatsApp Button entfernt */

/* ======================================
   19. CTA SECTION
   ====================================== */

.cta-section {
  background-color: #b71c1c;
  color: #ffffff;
  padding-top: 60px;
  padding-bottom: 60px;
  text-align: center;
}

.cta-section h2 {
  color: #ffffff;
  margin-bottom: 20px;
}

.cta-section p {
  color: #ffffff;
  font-size: 18px;
  margin-bottom: 30px;
  line-height: 1.6;
}

.cta-section .btn {
  background-color: #ffffff;
  color: #b71c1c;
}

.cta-section .btn:hover {
  background-color: #f0f0f0;
}

/* ======================================
   20. SECTION STYLES
   ====================================== */

section {
  padding-top: 60px;
  padding-bottom: 60px;
  width: 100%;
}

section.alternate {
  background-color: #f9f9f9;
}

section h2 {
  text-align: center;
  margin-bottom: 50px;
}

section h2.red-accent {
  color: #711210;
}

.section-subtitle {
  text-align: center;
  color: #666666;
  font-size: 18px;
  margin-bottom: 40px;
}

@media (max-width: 768px) {
  section {
    padding-top: 40px;
    padding-bottom: 40px;
  }

  section h2 {
    margin-bottom: 30px;
  }
}

/* ======================================
   21. RESPONSIVE UTILITIES
   ====================================== */

.hide-mobile {
  display: block;
}

.show-mobile {
  display: none;
}

@media (max-width: 768px) {
  .hide-mobile {
    display: none;
  }

  .show-mobile {
    display: block;
  }
}

/* ======================================
   22. IMAGE STYLES
   ====================================== */

img {
  max-width: 100%;
  height: auto;
  display: block;
}

.img-responsive {
  width: 100%;
  height: auto;
}

.img-circle {
  border-radius: 50%;
  aspect-ratio: 1;
  object-fit: cover;
}

/* ======================================
   23. UTILITY CLASSES
   ====================================== */

.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

.text-white {
  color: #ffffff;
}

.text-dark {
  color: #333333;
}

.text-muted {
  color: #999999;
}

.text-uppercase {
  text-transform: uppercase;
  letter-spacing: 1px;
}

.text-italic {
  font-style: italic;
}

.text-bold {
  font-weight: 700;
}

.mt-0 { margin-top: 0; }
.mt-10 { margin-top: 10px; }
.mt-20 { margin-top: 20px; }
.mt-30 { margin-top: 30px; }
.mt-40 { margin-top: 40px; }
.mt-50 { margin-top: 50px; }

.mb-0 { margin-bottom: 0; }
.mb-10 { margin-bottom: 10px; }
.mb-20 { margin-bottom: 20px; }
.mb-30 { margin-bottom: 30px; }
.mb-40 { margin-bottom: 40px; }
.mb-50 { margin-bottom: 50px; }

.pt-20 { padding-top: 20px; }
.pt-30 { padding-top: 30px; }
.pt-40 { padding-top: 40px; }
.pt-50 { padding-top: 50px; }

.pb-20 { padding-bottom: 20px; }
.pb-30 { padding-bottom: 30px; }
.pb-40 { padding-bottom: 40px; }
.pb-50 { padding-bottom: 50px; }

.no-margin {
  margin: 0;
}

.no-padding {
  padding: 0;
}

.clearfix::after {
  content: '';
  display: table;
  clear: both;
}

/* ======================================
   24. TRANSITIONS & ANIMATIONS
   ====================================== */

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(20px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes slideDown {
  from {
    transform: translateY(-20px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.fade-in {
  animation: fadeIn 0.3s ease;
}

.slide-up {
  animation: slideUp 0.5s ease;
}

.slide-down {
  animation: slideDown 0.3s ease;
}

/* ======================================
   25. PRINT STYLES
   ====================================== */

@media print {
  body {
    background-color: #ffffff;
    color: #000000;
  }

  a {
    color: #000000;
    text-decoration: underline;
  }

  header, footer {
    display: none;
  }

  section {
    page-break-inside: avoid;
  }
}

/* ======================================
   20. INFOS / FAQ PAGE
   ====================================== */

.faq-page-content {
  padding: 60px 0;
}

.faq-two-col {
  display: grid;
  grid-template-columns: 65% 32%;
  gap: 3%;
  margin-bottom: 40px;
}

.faq-text-col h1 {
  font-size: 22px;
  font-weight: 700;
  color: #333333;
  text-transform: uppercase;
  margin-bottom: 10px;
}

.faq-text-col h3 {
  font-size: 22px;
  font-weight: 700;
  color: #711210;
  margin-bottom: 15px;
  margin-top: 30px;
}

.faq-text-col p {
  font-size: 15px;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 15px;
}

.faq-text-col p strong {
  color: #333333;
}

.faq-images-col {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.faq-images-col img {
  width: 100%;
  height: auto;
  display: block;
}

.faq-gallery {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  margin-bottom: 0;
  overflow: hidden;
}

.faq-gallery img {
  width: 100%;
  height: 280px;
  object-fit: cover;
  display: block;
}

.faq-section {
  padding: 60px 0;
}

.faq-section h2 {
  font-size: 36px;
  font-weight: 700;
  color: #333333;
  margin-bottom: 30px;
  text-align: left;
}

.faq-section h3 {
  font-size: 22px;
  font-weight: 700;
  color: #711210;
  margin-bottom: 10px;
}

.faq-section .faq-answer-text {
  padding-left: 20px;
  border-left: 2px solid #eeeeee;
  margin-bottom: 30px;
}

.faq-section .faq-answer-text p {
  font-size: 15px;
  color: #666666;
  line-height: 1.8;
}

.faq-section .faq-answer-text p strong {
  color: #333333;
  font-style: italic;
}

@media (max-width: 768px) {
  .faq-two-col {
    grid-template-columns: 1fr;
  }

  .faq-gallery {
    grid-template-columns: repeat(2, 1fr);
  }

  .faq-gallery img {
    height: 180px;
  }
}

/* ======================================
   21. ÜBER UNS PAGE
   ====================================== */

.about-hero {
  background: linear-gradient(135deg, #b71c1c 0%, #c62828 30%, #d32f2f 60%, #b71c1c 100%);
  color: #ffffff;
  padding: 80px 0;
  text-align: left;
}

.about-hero h1 {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: 2px;
  margin-bottom: 30px;
  text-transform: uppercase;
  color: #ffffff;
}

.about-intro {
  font-size: 16px;
  line-height: 1.8;
  max-width: 1080px;
  color: #ffffff;
  text-align: left;
}

.team-section,
.team-section * {
  color: #ffffff;
}

.team-section {
  padding: 60px 0;
  background: linear-gradient(160deg, #c62828 0%, #b71c1c 40%, #8e0000 100%);
}

.team-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  margin-bottom: 60px;
}

.team-region {
  display: flex;
  flex-direction: column;
  gap: 40px;
}

.team-region-title {
  font-size: 28px;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 20px;
  text-transform: none;
  letter-spacing: 0;
  border-bottom: none;
  padding-bottom: 0;
  text-align: center;
}

.team-member {
  background-color: transparent;
  padding: 0;
  overflow: hidden;
  text-align: center;
}

.team-member-image {
  width: 250px;
  height: 250px;
  object-fit: cover;
  display: block;
  border-radius: 50%;
  margin: 0 auto 20px;
  border: none;
}

.team-member-content {
  padding: 10px 20px;
}

.team-member-name,
.team-member-name h3,
.team-member h3 {
  font-size: 28px;
  font-weight: 700;
  color: #ffffff !important;
  margin-bottom: 5px;
}

.team-member-title,
.team-member-title span {
  font-size: 0.95rem;
  color: #ffffff !important;
  font-weight: 400;
  font-style: italic;
  margin-bottom: 15px;
}

.team-member-bio,
.team-member-bio p,
.team-member p,
.team-member-content p {
  font-size: 0.95rem;
  line-height: 1.7;
  color: #ffffff !important;
}

.team-member-bio em,
.team-member-region {
  color: #ffeb3b !important;
  font-style: italic;
  display: block;
  margin-top: 10px;
}

.features-section {
  display: flex;
  justify-content: center;
  gap: 50px;
  flex-wrap: wrap;
  margin-top: 60px;
  padding-top: 60px;
  border-top: 2px solid rgba(255, 255, 255, 0.3);
}

.feature {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 250px;
}

.feature-icon {
  width: 70px;
  height: 70px;
  background-color: transparent;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15px;
  color: #ffffff;
  font-size: 70px;
}

.feature-text {
  font-size: 18px;
  font-weight: 700;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  line-height: 1.4;
}

@media (max-width: 768px) {
  .team-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .about-hero h1 {
    font-size: 2rem;
  }

  .features-section {
    gap: 30px;
  }

  .feature {
    max-width: 200px;
  }
}

/* ======================================
   END OF STYLESHEET
   ====================================== */
